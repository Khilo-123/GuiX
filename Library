local GuiX = {}

local UIS = game:GetService("UserInputService")

window = nil

function GuiX:CreateWindow(data)
	Title_data = data.Title or data.title or "GuiX"
	Draggable_data = data.Draggable or data.draggable or false
	PosX_data = data.PosX or data.posX or 0
	PosY_data = data.PosY or data.posY or 0
	CloseKey_data = data.CloseKey or data.closeKey or nil
	Visible_data = data.Visible or data.visible or true
	-- Gui to Lua
	-- Version: 3.2

	-- Instances:

	local Window = Instance.new("ScreenGui")
	local WindowFrame = Instance.new("Frame")
	local UICorner = Instance.new("UICorner")
	local Title = Instance.new("TextLabel")
	local TabButtonsFrame = Instance.new("Frame")
	local TabButtonsList = Instance.new("ScrollingFrame")
	local TemplateTabButton = Instance.new("TextButton")
	local UICorner_2 = Instance.new("UICorner")
	local TabsFrame = Instance.new("Frame")
	local TabTemplate = Instance.new("Frame")
	local TabContentList = Instance.new("ScrollingFrame")
	local UIListLayout = Instance.new("UIListLayout")
	local TabTitle = Instance.new("TextLabel")

	--Properties:

	Window.Name = "Window"
	Window.Parent = game.Players.LocalPlayer:WaitForChild("PlayerGui")
	Window.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

	WindowFrame.Name = "WindowFrame"
